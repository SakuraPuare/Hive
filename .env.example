# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ===== Cloudflare Tunnel =====
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_ZONE_ID=
CF_DOMAIN=yourdomain.com          # 节点 URL: edge-<mac6>.yourdomain.com

# ===== Tailscale =====
# 在 Tailscale 控制台生成：Settings → Keys → Auth Keys
# 勾选 Reusable（可复用），不要选 Ephemeral（临时，断线会删除设备记录）
TAILSCALE_AUTHKEY=tskey-auth-xxxxx

# ===== EasyTier =====
EASYTIER_NETWORK_NAME=edge-fleet
EASYTIER_SECRET=
EASYTIER_RELAY=your-relay-server.com    # 运行 easytier-core 的中继节点地址

# ===== FRP 服务端 =====
FRP_SERVER_ADDR=your-vps.example.com
FRP_SERVER_PORT=7000
FRP_AUTH_TOKEN=

# ===== Node Registry（可选，留空则跳过注册）=====
NODE_REGISTRY_URL=http://your-vps.example.com:8080
