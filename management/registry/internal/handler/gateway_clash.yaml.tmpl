# Hive Gateway (透明代理网关) - {{ .Title }}
# Generated by hive-registry — 由 hive-clash-sync 拉取并热重载，请勿手改

mixed-port: 7890
allow-lan: true
mode: Rule
log-level: info
ipv6: true
find-process-mode: always
unified-delay: true
tcp-concurrent: true
keep-alive-interval: 15
global-client-fingerprint: chrome

# 局域网可视化面板（MetaCubeXD）：external-controller 监听全网段，
# 同网段设备可访问 http://<lan-ip>:9090/ui。secret 由节点 MAC 派生做 API 鉴权。
external-controller: 0.0.0.0:9090
secret: "{{ .Secret }}"
external-ui: "{{ .DashboardPath }}"
external-ui-name: metacubexd

geodata-mode: true
geo-auto-update: true
geo-update-interval: 24

profile:
  store-selected: true
  store-fake-ip: true

# TUN + auto-redirect：只接管"转发流量"（下游 LAN/WiFi 设备经本机的包），
# 本机自身 OUTPUT 不进 TUN，配合下方 PROCESS-NAME 直连，杜绝出口 Xray 回环。
tun:
  enable: true
  stack: mixed
  auto-route: true
  auto-redirect: true
  auto-detect-interface: true
  dns-hijack:
    - any:53
    - tcp://any:53

sniffer:
  enable: true
  parse-pure-ip: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]

dns:
  enable: true
  listen: 0.0.0.0:1053
  cache-algorithm: arc
  respect-rules: true
  use-hosts: true
  use-system-hosts: true
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - rule-set:private_domain
    - rule-set:cn_domain
  proxy-server-nameserver:
    - https://223.5.5.5/dns-query
    - https://1.1.1.1/dns-query
  direct-nameserver:
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
  nameserver:
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
    - https://1.1.1.1/dns-query

proxies:
  - name: "直连"
    type: direct
    udp: true
{{ range .Proxies }}
  - name: {{ .Name }}
    type: vless
    server: {{ .Server }}
    port: 443
    uuid: {{ .UUID }}
    network: ws
    tls: true
    udp: true
    servername: {{ .Server }}
    ws-opts:
      path: /{{ $.XrayPath }}
      headers:
        Host: {{ .Server }}
      max-early-data: 2560
      early-data-header-name: Sec-WebSocket-Protocol
{{ end }}
proxy-groups:
{{ if .HasUpstream }}
  # 代理：默认指向"自动选择"，可在面板切到"手动选择"或具体节点
  - name: 代理
    type: select
    proxies: [自动选择, 手动选择, 直连]

  # 自动选择：url-test 在全部上游里挑最快（已在后端排除本节点，不会自选自己）
  - name: 自动选择
    type: url-test
    include-all: true
    exclude-type: direct
    tolerance: 10
    url: http://www.gstatic.com/generate_204
    interval: 300

  # 手动选择：UI 里手动指定上游出口
  - name: 手动选择
    type: select
    proxies: [{{ range $i, $n := .ManualProxyNames }}{{ if $i }}, {{ end }}{{ $n | printf "%q" }}{{ end }}{{ if not .ManualProxyNames }}直连{{ end }}]
{{ end }}
rule-anchor:
  ip: &ip {type: http, interval: 86400, behavior: ipcidr, format: mrs}
  domain: &domain {type: http, interval: 86400, behavior: domain, format: mrs}

rule-providers:
{{ range .DomainProviders }}
  {{ .Key }}:
    <<: *domain
    url: "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/{{ .File }}.mrs"
{{ end }}
{{ range .IPProviders }}
  {{ .Key }}:
    <<: *ip
    url: "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/{{ .File }}.mrs"
{{ end }}
rules:
  # ── 防回环：本机自身出站守护进程一律直连，绝不进代理 ──
{{ range .LocalProcessNames }}
  - PROCESS-NAME,{{ . }},直连
{{ end }}
  # ── 私有/本地网段直连 ──
  - RULE-SET,private_domain,直连
  - RULE-SET,private_ip,直连,no-resolve
  # ── 国内（geosite/geoip CN）：按节点方向决定走向 ──
  - RULE-SET,cn_domain,{{ .CNAction }}
  - RULE-SET,cn_ip,{{ .CNAction }},no-resolve
  # ── 其余流量：按节点方向决定走向 ──
  - MATCH,{{ .OtherAction }}
