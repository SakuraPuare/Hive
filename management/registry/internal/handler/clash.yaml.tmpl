# Hive Node Registry - {{ .Title }}
# Generated by hive-registry

mixed-port: 7890
allow-lan: true
mode: Rule
log-level: info
ipv6: true
find-process-mode: "off"
unified-delay: true
tcp-concurrent: true
keep-alive-interval: 15
keep-alive-idle: 45
global-client-fingerprint: chrome

geodata-mode: true
geo-auto-update: true
geo-update-interval: 24

profile:
  store-selected: true
  store-fake-ip: true

tun:
  enable: true
  stack: mixed
  auto-route: true
  auto-detect-interface: true
  dns-hijack:
    - any:53
    - tcp://any:53

sniffer:
  enable: true
  parse-pure-ip: true
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 8443]
    QUIC:
      ports: [443, 8443]

dns:
  enable: true
  listen: 0.0.0.0:1053
  cache-algorithm: arc
  respect-rules: true
  use-hosts: true
  use-system-hosts: true
  ipv6: true
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-filter-mode: blacklist
  fake-ip-filter:
    - rule-set:private_domain
    - rule-set:cn_domain
  proxy-server-nameserver:
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
  direct-nameserver:
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
  nameserver:
    - https://223.5.5.5/dns-query
    - https://223.6.6.6/dns-query
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query

proxies:
  - name: "直连"
    type: direct
    udp: true
{{ range .Proxies }}
  - name: {{ .Name }}
    type: vless
    server: {{ .Server }}
    port: 443
    uuid: {{ .UUID }}
    network: ws
    tls: true
    udp: true
    servername: {{ .Server }}
    ws-opts:
      path: /{{ $.XrayPath }}
      headers:
        Host: {{ .Server }}
      max-early-data: 2560
      early-data-header-name: Sec-WebSocket-Protocol
{{ end }}
proxy-groups:
  - name: 默认
    type: select
    proxies: [自动选择,直连,香港,台湾,日本,新加坡,美国,巴西,其它地区,全部节点]

{{ range .ServiceGroups }}
  - name: {{ .Name }}
    type: select
    proxies: [{{ .First }},自动选择,直连,香港,台湾,日本,新加坡,美国,巴西,其它地区,全部节点]
{{ end }}
  - name: 国内
    type: select
    proxies: [直连,自动选择,香港,台湾,日本,新加坡,美国,巴西,其它地区,全部节点]

  - name: 其他
    type: select
    proxies: [自动选择,直连,香港,台湾,日本,新加坡,美国,巴西,其它地区,全部节点]

{{ range .RegionGroups }}
  - name: {{ .Name }}
    type: url-test
    include-all: true
    exclude-type: direct
    filter: {{ .Filter }}
    url: http://www.gstatic.com/generate_204
    interval: 300
    tolerance: 10
{{ end }}
  - name: 全部节点
    type: select
    include-all: true
    exclude-type: direct

  - name: 自动选择
    type: url-test
    include-all: true
    exclude-type: direct
    tolerance: 10
    url: http://www.gstatic.com/generate_204
    interval: 300

rule-anchor:
  ip: &ip {type: http, interval: 86400, behavior: ipcidr, format: mrs}
  domain: &domain {type: http, interval: 86400, behavior: domain, format: mrs}

rule-providers:
{{ range .DomainProviders }}
  {{ .Key }}:
    <<: *domain
    url: "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geosite/{{ .File }}.mrs"
{{ end }}
{{ range .IPProviders }}
  {{ .Key }}:
    <<: *ip
    url: "https://raw.githubusercontent.com/MetaCubeX/meta-rules-dat/meta/geo/geoip/{{ .File }}.mrs"
{{ end }}
rules:
  - AND,(AND,(DST-PORT,443),(NETWORK,UDP)),(NOT,((GEOSITE,cn))),REJECT
  - RULE-SET,private_ip,直连,no-resolve
  - RULE-SET,github_domain,Github
  - RULE-SET,twitter_domain,Twitter
  - RULE-SET,youtube_domain,YouTube
  - RULE-SET,google_domain,Google
  - RULE-SET,telegram_domain,Telegram
  - RULE-SET,netflix_domain,NETFLIX
  - RULE-SET,bilibili_domain,哔哩哔哩
  - RULE-SET,bahamut_domain,巴哈姆特
  - RULE-SET,spotify_domain,Spotify
  - RULE-SET,cn_domain,国内
  - RULE-SET,geolocation-!cn,其他
  - RULE-SET,google_ip,Google
  - RULE-SET,netflix_ip,NETFLIX
  - RULE-SET,telegram_ip,Telegram
  - RULE-SET,twitter_ip,Twitter
  - RULE-SET,cn_ip,国内
  - MATCH,其他
